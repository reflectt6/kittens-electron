{
  "name": "kittens-game",
  "version": "1.5.0.2",
  "description": "Kittens Game - Desktop Edition",
  "main": "main.js",
  "author": "bloodrizer (original game), Desktop port",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:dir": "electron-builder --win dir"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.kittensgame.desktop",
    "productName": "Kittens Game",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "app/**/*",
      "app/**/*.js",
      "app/**/*.css",
      "app/**/*.gif",
      "app/**/*.json"
    ],
    "win": {
      "target": "portable",
      "icon": "app/res/favicon.png"
    },
    "portable": {
      "artifactName": "KittensGame-${version}.exe"
    }
  }
}
